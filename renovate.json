{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": ["/\\.csproj$/"],
      "matchStrings": [
        "<TargetFramework>net(?<currentValue>\\d+\\.\\d+)</TargetFramework>"
      ],
      "depNameTemplate": "dotnet-targetframework",
      "datasourceTemplate": "github-tags",
      "packageNameTemplate": "dotnet/runtime",
      "extractVersionTemplate": "^v?(?<version>\\d+\\.\\d+)",
      "versioningTemplate": "semver"
    }
  ],
  "packageRules": [
    {
      "matchUpdateTypes": ["patch", "minor"],
      "automerge": true
    },
    {
      "matchPackageNames": [
        "dotnet-targetframework",
        "mcr.microsoft.com/dotnet/*"
      ],
      "groupName": ".NET version",
      "groupSlug": "dotnet-version"
    }
  ]
}
