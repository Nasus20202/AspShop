{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": ["/\\.csproj$/"],
      "matchStrings": ["<TargetFramework>net(?<currentValue>.+)</TargetFramework>"],
      "depNameTemplate": "dotnet-targetframework",
      "datasourceTemplate": "github-tags",
      "packageNameTemplate": "dotnet/runtime",
      "versioningTemplate": "semver-coerced"
    }
  ],
  "packageRules": [
    {
      "matchUpdateTypes": ["patch", "minor"],
      "automerge": true
    },
    {
      "matchPackageNames": ["dotnet-targetframework"],
      "groupName": ".NET version",
      "groupSlug": "dotnet-version"
    }
  ]
}
